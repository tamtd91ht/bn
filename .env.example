# ==============================================================
# Binance Auto-Trading Bot - biến môi trường
# COPY file này thành `.env` rồi điền giá trị thật.
# TUYỆT ĐỐI KHÔNG COMMIT `.env` lên git (đã có trong .gitignore).
# ==============================================================

# --- Binance API ---
# Tạo tại: https://www.binance.com/en/my/settings/api-management
# Cấu hình key:
#   [x] Enable Reading
#   [x] Enable Spot & Margin Trading
#   [ ] Enable Withdrawals            (TẮT - không cho bot rút tiền)
#   [ ] Enable Futures                (không dùng)
#   IP access: Restrict access to trusted IPs only → điền IP tĩnh VPS
BINANCE_API_KEY=your_api_key_here_without_quotes
BINANCE_API_SECRET=your_api_secret_here_without_quotes

# --- Telegram (tuỳ chọn) ---
# Tạo bot: chat với @BotFather → /newbot → lấy HTTP API token
TELEGRAM_BOT_TOKEN=123456789:AA_replace_with_your_token

# Lấy chat_id: gửi 1 tin nhắn cho bot, rồi mở:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# Tìm "chat":{"id": 123456789} → copy số đó vào đây.
# Nếu dùng group: thêm bot vào group, rồi dùng chat_id âm (-100...).
TELEGRAM_CHAT_ID=123456789

# --- Log level override (tuỳ chọn) ---
# Uncomment để bật DEBUG khi troubleshoot. INFO là mặc định.
# LOG_LEVEL=DEBUG
